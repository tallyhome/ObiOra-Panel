APP_NAME="ObiOra Panel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=obiora_panel
DB_USERNAME=obiora
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

# Laravel Reverb (Phase 11 — activé par défaut, false pour désactiver)
OBIORA_REALTIME_ENABLED=true
OBIORA_REALTIME_METRICS_INTERVAL=5
OBIORA_REALTIME_FALLBACK_POLL=10
REVERB_APP_ID=obiora-panel
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="panel@obiora.local"
MAIL_FROM_NAME="${APP_NAME}"

# ObiOra Panel
OBIORA_NAME="ObiOra Panel"
OBIORA_INSTALLATION_UUID=
OBIORA_GITHUB_REPO=tallyhome/ObiOra-Panel
OBIORA_GITHUB_API=https://api.github.com
OBIORA_LICENSE_ENABLED=false
OBIORA_ADMIN_LICENCE_URL=
OBIORA_LICENSE_GRACE_DAYS=7

# Obiora Monitor / Doctor
OBIORA_DOCTOR_SIGNING_KEY=
OBIORA_DOCTOR_REQUIRE_SIGNATURE=false
OBIORA_MONITOR_PING_INTERVAL=30
OBIORA_MONITOR_HISTORY_HOURS=24
OBIORA_MONITOR_ALERTS_EMAIL=true
OBIORA_MONITOR_STREAM_INTERVAL=5

# Assistant IA (Phase 12) — activé par défaut ; mode local sans clé API
OBIORA_AI_ENABLED=true
# Providers : deepseek (recommandé), ollama, openai, anthropic, moonshot (Kimi)
OBIORA_AI_PROVIDER=deepseek
OBIORA_AI_API_KEY=
# DeepSeek : https://api.deepseek.com/v1 | Ollama : http://127.0.0.1:11434/v1
OBIORA_AI_BASE_URL=
OBIORA_AI_MODEL=deepseek-chat
OBIORA_AI_MAX_TOKENS=2048

# Temps réel Reverb — poll dashboard 0 = WebSocket uniquement
OBIORA_REALTIME_FALLBACK_POLL=0

# ObiOra-Suite (Phase 13 — lien panel seedbox)
OBIORA_SUITE_URL=

VITE_APP_NAME="${APP_NAME}"
