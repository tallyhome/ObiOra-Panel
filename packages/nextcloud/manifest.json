{
    "slug": "nextcloud",
    "name": "Nextcloud",
    "description": "Suite bureautique et cloud privé.",
    "version": "1.0.0",
    "category": "cloud",
    "source": "swizzin-catalog",
    "scripts": {
        "install": "install.sh",
        "uninstall": "uninstall.sh"
    },
    "database": {
        "auto_provision": true,
        "name_prefix": "nextcloud"
    },
    "install": {
        "options": [
            {
                "name": "label",
                "label": "Nom affiché dans le panel",
                "type": "text",
                "default": "Nextcloud",
                "help": "Libellé visible dans le centre de contrôle."
            },
            {
                "name": "username",
                "label": "Identifiant administrateur Nextcloud",
                "type": "text",
                "default": "admin",
                "required": true,
                "min": 3,
                "help": "Utilisé lors de l'assistant web Nextcloud (première connexion)."
            },
            {
                "name": "pass",
                "label": "Mot de passe administrateur",
                "type": "password",
                "required": true,
                "min": 8
            },
            {
                "name": "pass2",
                "label": "Confirmer le mot de passe",
                "type": "password",
                "required": true,
                "matches": "pass"
            }
        ]
    },
    "runtime": {
        "type": "docker",
        "container": "obiora-nextcloud",
        "port": 8443,
        "url": "https://{host}:8443",
        "usage": "Suite bureautique et cloud privé."
    }
}
