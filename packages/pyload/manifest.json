{
    "slug": "pyload",
    "name": "pyLoad",
    "description": "Gestionnaire de téléchargements HTTP/FTP.",
    "version": "1.0.0",
    "category": "download",
    "source": "swizzin-catalog",
    "scripts": {
        "install": "install.sh",
        "uninstall": "uninstall.sh"
    },
    "runtime": {
        "type": "docker",
        "container": "obiora-pyload",
        "port": 8000,
        "url": "http://{host}:8000",
        "usage": "Gestionnaire de téléchargements HTTP/FTP. Identifiants définis à l'installation via le wizard du panel."
    },
    "install": {
        "options": [
            {
                "name": "label",
                "label": "Nom affiché dans le panel",
                "type": "text",
                "default": "Pyload",
                "help": "Libellé visible dans le centre de contrôle."
            },
            {
                "name": "username",
                "label": "Identifiant",
                "type": "text",
                "default": "admin",
                "required": true,
                "min": 3
            },
            {
                "name": "pass",
                "label": "Mot de passe",
                "type": "password",
                "required": true,
                "min": 1,
                "help": "Stocké dans les infos de l'application après installation."
            }
        ]
    }
}
