{
    "slug": "filebrowser",
    "name": "File Browser",
    "description": "Gestionnaire de fichiers web.",
    "version": "1.0.0",
    "category": "cloud",
    "source": "swizzin-catalog",
    "scripts": {
        "install": "install.sh",
        "uninstall": "uninstall.sh"
    },
    "install": {
        "options": [
            {
                "name": "label",
                "label": "Nom affiché dans le panel",
                "type": "text",
                "default": "File Browser",
                "help": "Libellé visible dans le centre de contrôle. Modifiable plus tard."
            },
            {
                "name": "username",
                "label": "Identifiant administrateur",
                "type": "text",
                "default": "admin",
                "required": true,
                "min": 3
            },
            {
                "name": "pass",
                "label": "Mot de passe administrateur",
                "type": "password",
                "required": true,
                "min": 1,
                "help": "Mot de passe de votre choix. ObiOra configure File Browser pour accepter ce mot de passe dès l'installation."
            }
        ]
    },
    "runtime": {
        "type": "docker",
        "container": "obiora-filebrowser",
        "port": 8082,
        "url": "http://{host}:8082",
        "usage": "Gestionnaire de fichiers web."
    }
}
