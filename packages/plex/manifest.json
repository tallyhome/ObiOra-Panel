{
    "slug": "plex",
    "name": "Plex",
    "description": "Serveur média Plex (films, séries, musique).",
    "version": "1.0.0",
    "category": "media",
    "scripts": {
        "install": "install.sh",
        "uninstall": "uninstall.sh"
    },
    "install": {
        "options": [
            {
                "name": "label",
                "label": "Nom affiché dans le panel",
                "type": "text",
                "default": "Plex"
            },
            {
                "name": "plex_claim",
                "label": "Token Plex Claim (optionnel)",
                "type": "text",
                "required": false,
                "help": "Obtenez un token sur https://plex.tv/claim (valide ~4 min) pour lier automatiquement le serveur."
            }
        ]
    },
    "runtime": {
        "type": "docker",
        "container": "obiora-plex",
        "port": 32400,
        "url": "http://{host}:32400/web",
        "usage": "Plex en mode host (port 32400). Optionnel : token claim plex.tv pour lier le serveur sans ouverture manuelle."
    }
}
